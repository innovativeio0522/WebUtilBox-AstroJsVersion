---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  canonical: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  keywords?: string;
  jsonLd?: object | object[];
}

const {
  title,
  description,
  canonical,
  ogTitle,
  ogDescription,
  ogImage = 'https://webutilbox.com/assets/og-image.png',
  keywords,
  jsonLd,
} = Astro.props;

const resolvedOgTitle = ogTitle ?? title;
const resolvedOgDesc  = ogDescription ?? description;

// Get GA4 measurement ID from environment variable
const gaMeasurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Preconnect -->
  <link rel="preconnect" href="https://pagead2.googlesyndication.com" />
  <link rel="dns-prefetch" href="https://pagead2.googlesyndication.com" />

  <title>{title}</title>
  <meta name="description" content={description} />
  {keywords && <meta name="keywords" content={keywords} />}
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={resolvedOgTitle} />
  <meta property="og:description" content={resolvedOgDesc} />
  <meta property="og:image" content={ogImage} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:url" content={canonical} />
  <meta name="twitter:title" content={resolvedOgTitle} />
  <meta name="twitter:description" content={resolvedOgDesc} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Critical CSS inlined for instant render -->
  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    :root{--primary:#f97316;--primary-dark:#ea580c;--dark:#0a0a0a;--gray:#a1a1aa;--white:#fafafa;--card-bg:#18181b;--border:#27272a}
    body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Oxygen,Ubuntu,Cantarell,sans-serif;background:#000;background-image:radial-gradient(at 0% 0%,rgba(249,115,22,.25) 0px,transparent 50%),radial-gradient(at 100% 0%,rgba(251,146,60,.20) 0px,transparent 50%),radial-gradient(at 100% 100%,rgba(249,115,22,.22) 0px,transparent 50%),radial-gradient(at 0% 100%,rgba(251,146,60,.18) 0px,transparent 50%);background-attachment:fixed;min-height:100vh;color:var(--white)}
    header{background:rgba(10,10,10,.9);backdrop-filter:blur(10px);border-bottom:1px solid var(--border);padding:20px 0;position:sticky;top:0;z-index:100}
    .header-content{max-width:1000px;margin:0 auto;padding:0 20px;display:flex;justify-content:space-between;align-items:center}
    .logo{display:flex;align-items:center;gap:12px;color:var(--white);text-decoration:none;font-size:1.5rem;font-weight:700;line-height:1}
    .logo span:first-child{font-size:2rem;line-height:1;display:flex;align-items:center}
    .all-tools-btn{padding:10px 20px;background:var(--primary);color:var(--white);text-decoration:none;border-radius:8px;font-weight:600;font-size:.95rem;transition:all .3s}
    .container{max-width:1000px;margin:0 auto;padding:40px 20px}
    h1{font-size:2.5rem;margin-bottom:15px;background:linear-gradient(135deg,#fb923c 0%,#ea580c 50%,#dc2626 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
    .subtitle{color:var(--gray);font-size:1.1rem;margin-bottom:30px}
  </style>

  <!-- Google tag (gtag.js) -->
  {gaMeasurementId && (
    <script is:inline set:html={`
      const initAnalytics = () => {
        const script = document.createElement('script');
        script.async = true;
        script.src = "https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}";
        document.head.appendChild(script);

        window.dataLayer = window.dataLayer || [];
        window.gtag = function gtag(){ window.dataLayer.push(arguments); };
        window.gtag('js', new Date());
        window.gtag('config', "${gaMeasurementId}");
      };

      if ('requestIdleCallback' in window) {
        requestIdleCallback(initAnalytics);
      } else {
        window.addEventListener('load', initAnalytics);
      }
    `} />
  )}

  <!-- AdSense -->
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3916624682784320" crossorigin="anonymous"></script>

  <!-- JSON-LD Structured Data -->
  {jsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  )}

  <!-- Slot for page-specific head content -->
  <slot name="head" />
</head>
<body>
  <slot />

  <footer style="background: var(--dark); padding: 30px 20px; text-align: center; margin-top: 60px; border-top: 1px solid var(--border);">
    <div style="max-width: 1000px; margin: 0 auto;">
      <p style="color: var(--gray); margin-bottom: 15px;">© 2026 Webutilbox. All rights reserved.</p>
      <div>
            <a href="/" style="color: var(--primary); text-decoration: none; margin: 0 15px;">Home</a>
            <a href="/tools" style="color: var(--primary); text-decoration: none; margin: 0 15px;">All Tools</a>
            <a href="/blog" style="color: var(--primary); text-decoration: none; margin: 0 15px;">Blog</a>
            <a href="/about" style="color: var(--primary); text-decoration: none; margin: 0 15px;">About</a>
            <a href="/contact" style="color: var(--primary); text-decoration: none; margin: 0 15px;">Contact</a>
            <a href="/backlinks" style="color: var(--primary); text-decoration: none; margin: 0 15px;">Backlinks</a>
            <a href="/privacy-policy" style="color: var(--primary); text-decoration: none; margin: 0 15px;">Privacy Policy</a>
        </div>
    </div>
  </footer>

  <div id="toast" class="toast">
    <span id="toastMessage">Success!</span>
  </div>

  <!-- Shared utility functions used by all pages -->
  <script is:inline>
    function showToast(message, isError = false) {
      const toast = document.getElementById('toast');
      const msg = document.getElementById('toastMessage');
      msg.textContent = message;
      toast.className = 'toast show' + (isError ? ' error' : '');
      setTimeout(() => toast.classList.remove('show'), 3000);
    }
    function toggleFaq(btn) {
      btn.classList.toggle('open');
      btn.nextElementSibling.classList.toggle('open');
    }
    function toggleEmbed(btn) {
      btn.classList.toggle('open');
      btn.nextElementSibling.classList.toggle('open');
      btn.setAttribute('aria-expanded', btn.classList.contains('open'));
    }
    function copyPageLink() {
      navigator.clipboard.writeText(window.location.href).then(() => showToast('Link copied!'));
    }
    function copyEmbedCode(btn) {
      const ta = btn.previousElementSibling;
      navigator.clipboard.writeText(ta.value).then(() => showToast('Embed code copied!'));
    }
  </script>
</body>
</html>
