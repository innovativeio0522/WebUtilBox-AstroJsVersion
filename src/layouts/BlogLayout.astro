---
import BaseLayout from './BaseLayout.astro';
import '../styles/blog.css';

export interface Props {
  title: string;
  description: string;
  canonical: string;
  ogImage?: string;
  keywords?: string;
  jsonLd?: object | object[];
  
  // Post frontmatter details
  category: string;
  pubDate: Date;
  author: string;
  tags?: string[];
  relatedTool?: {
    name: string;
    href: string;
    icon: string;
  };
}

const {
  title,
  description,
  canonical,
  ogImage,
  keywords,
  jsonLd,
  category,
  pubDate,
  author,
  tags = [],
  relatedTool
} = Astro.props;

const formattedDate = new Date(pubDate).toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric'
});
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogImage={ogImage}
  keywords={keywords}
  jsonLd={jsonLd}
>
<div style="width: 100%; box-sizing: border-box; overflow-x: hidden;">
  <div class="blog-container">
    <main>
      <article class="blog-article">
        <!-- Breadcrumbs -->
        <div class="post-breadcrumb">
          <a href="/" style="color: var(--gray); text-decoration: none;">Home</a>
          <span>/</span>
          <a href="/blog" style="color: var(--gray); text-decoration: none;">Blog</a>
          <span>/</span>
          <span style="color: var(--primary); overflow-wrap: break-word; word-break: break-word;">{title}</span>
        </div>

        <!-- Header -->
        <header class="post-header" style="background: transparent; border: none; padding: 0; position: static; backdrop-filter: none;">
          <span class="post-category">{category}</span>
          <h1 class="post-title">{title}</h1>
          
          <div class="post-meta">
            <span>📅 {formattedDate}</span>
            <span>✍️ By {author}</span>
            {tags.length > 0 && (
              <span>🏷️ {tags.join(', ')}</span>
            )}
          </div>
        </header>

        <!-- Post Content -->
        <div class="post-content">
          <slot />
        </div>
      </article>
    </main>

    <!-- Sidebar -->
    <aside class="blog-sidebar">
      {relatedTool && (
        <div class="sidebar-card">
          <div style="font-size: 2.5rem; margin-bottom: 12px; text-align: center; line-height: 1;">{relatedTool.icon}</div>
          <h3 style="font-size: 1rem; margin-bottom: 10px; line-height: 1.4;">Try the {relatedTool.name}</h3>
          <p style="font-size: 0.85rem; line-height: 1.6; margin-bottom: 16px; color: var(--gray);">
            {description}
          </p>
          <a href={relatedTool.href} class="sidebar-tool-btn" style="font-size: 0.85rem; padding: 10px 12px; word-break: break-word;">
            Open {relatedTool.name} →
          </a>
        </div>
      )}

      <!-- Privacy Box -->
      <div class="sidebar-card" style="position: static;">
        <h3 style="font-size: 1rem; margin-bottom: 10px;">Privacy First 🔒</h3>
        <p style="font-size: 0.85rem; line-height: 1.6; color: var(--gray);">
          At Webutilbox, none of your data is ever uploaded to external servers. Everything runs strictly in-browser for complete confidentiality.
        </p>
      </div>
    </aside>
  </div>
</div>
</BaseLayout>
