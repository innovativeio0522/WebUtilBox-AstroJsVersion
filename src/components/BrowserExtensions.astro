---
export interface ExtensionItem {
  name: string;
  desc: string;
  icon: string;
  url: string;
  category: 'media' | 'finance' | 'productivity' | 'general';
}

export interface Props {
  category?: 'media' | 'finance' | 'productivity' | 'all';
}

const { category = 'all' } = Astro.props;

const allExtensions: ExtensionItem[] = [
  {
    name: 'YouTube Screenshot',
    desc: 'Capture 4K video frames in 1-click directly inside YouTube player.',
    icon: '📸',
    url: 'https://chromewebstore.google.com/detail/amghnlfcfhaomeemjjceljligefpekie?utm_source=item-share-cb',
    category: 'media',
  },
  {
    name: 'Tickerbuddy',
    desc: 'Real-time stock & crypto price ticker right in your browser toolbar.',
    icon: '📈',
    url: 'https://chromewebstore.google.com/detail/tickerbuddy-ai-technical/fpoicngadopbgccemailadhepfpgmblg',
    category: 'finance',
  },
  {
    name: 'TimeVault',
    desc: 'Instant UNIX timestamp, timezone conversion & schedule planner.',
    icon: '⏱️',
    url: 'https://chromewebstore.google.com/detail/cagjecoehllngmmcpdgbphldmbakpokp?utm_source=item-share-cb',
    category: 'productivity',
  },
];

const extensions = category === 'all'
  ? allExtensions
  : allExtensions.filter(e => e.category === category);
---

<div class="browser-extensions-card">
  <div class="extensions-header">
    <span class="extensions-badge">🚀 Free Extensions</span>
    <h3>Supercharge Your Browser</h3>
    <p>Useful Chrome & Edge extensions built by Webutilbox to save you time.</p>
  </div>
  <div class="extensions-grid">
    {extensions.map((ext) => (
      <a
        href={ext.url}
        target="_blank"
        rel="noopener noreferrer"
        class="extension-link"
        data-extension-name={ext.name}
      >
        <span class="extension-icon">{ext.icon}</span>
        <div class="extension-info">
          <strong>{ext.name}</strong>
          <p>{ext.desc}</p>
        </div>
        <span class="extension-btn">Get Extension ↗</span>
      </a>
    ))}
  </div>
</div>

<style>
  .browser-extensions-card {
    margin: 30px 0;
    padding: 24px;
    background: rgba(24, 24, 27, 0.6);
    border: 1px solid var(--border);
    border-radius: 14px;
  }
  .extensions-header {
    margin-bottom: 16px;
  }
  .extensions-badge {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--primary);
    background: rgba(249, 115, 22, 0.15);
    padding: 4px 10px;
    border-radius: 20px;
    display: inline-block;
    margin-bottom: 8px;
  }
  .extensions-header h3 {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 4px;
  }
  .extensions-header p {
    font-size: 0.88rem;
    color: var(--gray);
    margin: 0;
  }
  .extensions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 12px;
  }
  .extension-link {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 12px 16px;
    background: rgba(39, 39, 42, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 10px;
    text-decoration: none;
    transition: all 0.2s ease;
  }
  .extension-link:hover {
    background: rgba(249, 115, 22, 0.12);
    border-color: var(--primary);
    transform: translateY(-2px);
  }
  .extension-icon {
    font-size: 1.6rem;
    line-height: 1;
  }
  .extension-info {
    flex: 1;
    min-width: 0;
  }
  .extension-info strong {
    font-size: 0.92rem;
    color: var(--white);
    display: block;
    margin-bottom: 2px;
  }
  .extension-info p {
    font-size: 0.78rem;
    color: var(--gray);
    margin: 0;
    line-height: 1.3;
  }
  .extension-btn {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--primary);
    white-space: nowrap;
    opacity: 0.9;
  }
  .extension-link:hover .extension-btn {
    opacity: 1;
    text-decoration: underline;
  }
</style>
