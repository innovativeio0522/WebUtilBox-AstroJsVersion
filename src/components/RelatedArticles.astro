---
export interface ArticleItem {
  title: string;
  url: string;
  description: string;
  category?: string;
}

export interface Props {
  articles: ArticleItem[];
}

const { articles = [] } = Astro.props;
---

{articles && articles.length > 0 && (
  <div class="related-articles-card">
    <div class="related-articles-header">
      <span class="articles-badge">📚 Recommended Guides</span>
      <h3>Learn More & Master This Tool</h3>
    </div>
    <div class="related-articles-grid">
      {articles.map((item) => (
        <a href={item.url} class="article-card-link">
          {item.category && <span class="article-category">{item.category}</span>}
          <h4 class="article-title">{item.title}</h4>
          <p class="article-desc">{item.description}</p>
          <span class="article-read-btn">Read Full Guide →</span>
        </a>
      ))}
    </div>
  </div>
)}

<style>
  .related-articles-card {
    margin: 30px 0;
    padding: 24px;
    background: rgba(24, 24, 27, 0.6);
    border: 1px solid var(--border);
    border-radius: 14px;
  }
  .related-articles-header {
    margin-bottom: 20px;
  }
  .articles-badge {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: #38bdf8;
    background: rgba(56, 189, 248, 0.12);
    padding: 4px 10px;
    border-radius: 20px;
    display: inline-block;
    margin-bottom: 8px;
  }
  .related-articles-header h3 {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--white);
    margin: 0;
  }
  .related-articles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 16px;
  }
  .article-card-link {
    display: flex;
    flex-direction: column;
    padding: 16px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border);
    border-radius: 10px;
    text-decoration: none;
    transition: all 0.2s ease;
  }
  .article-card-link:hover {
    border-color: #38bdf8;
    background: rgba(56, 189, 248, 0.06);
    transform: translateY(-2px);
  }
  .article-category {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--gray);
    margin-bottom: 6px;
  }
  .article-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--white);
    margin: 0 0 8px 0;
    line-height: 1.4;
  }
  .article-desc {
    font-size: 0.82rem;
    color: var(--gray);
    margin: 0 0 12px 0;
    line-height: 1.5;
    flex-grow: 1;
  }
  .article-read-btn {
    font-size: 0.8rem;
    font-weight: 600;
    color: #38bdf8;
  }
</style>
