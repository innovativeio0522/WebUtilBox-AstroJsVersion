<ToolLayout
  title="BMI Calculator - Body Mass Index | Webutilbox"
  description="Calculate your Body Mass Index (BMI) in seconds using metric or imperial units. Includes BMI categories chart and health guidance. Free and private."
  canonical={canonical}
  ogImage="https://webutilbox.com/assets/og/og-calculators.svg"
  keywords="bmi calculator, body mass index calculator, calculate bmi online, bmi chart"
  h1="⚖️ BMI Calculator"
  subtitle="Calculate your Body Mass Index (BMI) and check if your weight is healthy."
  lastUpdated=""
  shareText="Free%20online%20BMI%20Calculator%20on%20Webutilbox.%20Privacy-focused%2C%20runs%20100%25%20in%20your%20browser."
