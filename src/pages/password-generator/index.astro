                    <input type="checkbox" id="useUpper" checked>
                    <label for="useUpper">Uppercase Letters (ABC)</label>
                </div>
                <div class="option-item">
                    <input type="checkbox" id="useLower" checked>
                    <label for="useLower">Lowercase Letters (abc)</label>
                </div>
                <div class="option-item">
                    <input type="checkbox" id="useNumbers" checked>
                    <label for="useNumbers">Numbers (123)</label>
                </div>
                <div class="option-item">
                    <input type="checkbox" id="useSymbols" checked>
                    <label for="useSymbols">Symbols (!@#$)</label>
                </div>
            </div>
            
            <div class="button-group">
                <button class="btn btn-primary" onclick="generatePassword()">Generate Password</button>
                <button class="btn btn-success" onclick="copyPassword()">Copy Password</button>
            </div>
            
