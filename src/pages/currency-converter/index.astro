<div class="workspace">
            <!-- Converter Grid -->
            <div style="display: grid; grid-template-columns: 1fr auto 1fr; gap: 15px; align-items: end; margin-bottom: 15px;">
                <!-- From -->
                <div>
                    <label style="font-size: 0.85rem; margin-bottom: 6px; display: block;">From</label>
                    <input type="number" id="fromValue" value="100" oninput="convert()" style="width: 100%; padding: 10px; font-size: 1rem; margin-bottom: 8px;">
                    <select id="fromCurrency" onchange="convert()" style="width: 100%; padding: 8px; font-size: 0.9rem;">
                        <option value="USD">???? USD - US Dollar</option>
                        <option value="EUR">???? EUR - Euro</option>
                        <option value="GBP">???? GBP - British Pound</option>
