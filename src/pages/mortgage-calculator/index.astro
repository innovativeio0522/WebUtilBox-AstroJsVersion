const jsonLd = {"@context":"https://schema.org","@graph":[{"@type":"WebApplication","name":"Mortgage Calculator - Calculate Monthly Payment & Amortization","url":"https://webutilbox.com/mortgage-calculator/","description":"Calculate mortgage payments and amortization schedule. Compare 15 vs 30 year mortgages. Free tool.","applicationCategory":"FinanceApplication","operatingSystem":"Web Browser","offers":{"@type":"Offer","price":"0","priceCurrency":"USD"},"creator":{"@type":"Organization","name":"Webutilbox","url":"https://webutilbox.com"}},{"@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What is included in a monthly mortgage payment?","acceptedAnswer":{"@type":"Answer","text":"A full mortgage payment (PITI) includes Principal (paying down the loan balance), Interest (cost of borrowing), Taxes (property taxes, often escrowed), and Insurance (homeowner's insurance, plus PMI if your down payment is under 20%)."}},{"@type":"Question","name":"What is PMI and when can I remove it?","acceptedAnswer":{"@type":"Answer","text":"PMI (Private Mortgage Insurance) is required when your down payment is less than 20%. It protects the lender if you default. Once your loan-to-value ratio reaches 80% (you have paid down 20% of the home's value), you can typically request PMI removal."}},{"@type":"Question","name":"How much house can I afford?","acceptedAnswer":{"@type":"Answer","text":"A common guideline is that your monthly housing costs should not exceed 28% of your gross monthly income, and total debt payments should not exceed 36%. Use this calculator to find a payment that fits within those limits given your income."}},{"@type":"Question","name":"What is the difference between a 15-year and 30-year mortgage?","acceptedAnswer":{"@type":"Answer","text":"A 15-year mortgage has higher monthly payments but you pay far less total interest and build equity faster. A 30-year mortgage has lower monthly payments but costs significantly more in total interest. The right choice depends on your cash flow and financial goals."}},{"@type":"Question","name":"How does a larger down payment affect my mortgage?","acceptedAnswer":{"@type":"Answer","text":"A larger down payment reduces your loan amount (lower monthly payments), eliminates or reduces PMI, and often qualifies you for a better interest rate. It also means you start with more equity in the home."}}]},{"@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://webutilbox.com/"},{"@type":"ListItem","position":2,"name":"All Tools","item":"https://webutilbox.com/Tools.html"},{"@type":"ListItem","position":3,"name":"Mortgage Calculator","item":"https://webutilbox.com/mortgage-calculator/"}]}]};
