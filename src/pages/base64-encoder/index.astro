                <th style="padding:10px 12px;color:var(--gray);font-weight:600">Base64</th>
                <th style="padding:10px 12px;color:var(--gray);font-weight:600">URL encoding (%xx)</th>
            </tr>
        </thead>
        <tbody>
            <tr style="border-bottom:1px solid var(--border)">
                <td style="padding:10px 12px">Character set</td>
                <td style="padding:10px 12px"><code>A-Z a-z 0-9 + / =</code></td>
                <td style="padding:10px 12px">Unreserved chars + <code>%XX</code> escapes</td>
            </tr>
            <tr style="border-bottom:1px solid var(--border)">
                <td style="padding:10px 12px">Size overhead</td>
                <td style="padding:10px 12px">~33% larger than input</td>
                <td style="padding:10px 12px">Varies — only special chars expand</td>
            </tr>
            <tr style="border-bottom:1px solid var(--border)">
                <td style="padding:10px 12px">Reversible?</td>
                <td style="padding:10px 12px">Yes — trivially</td>
                <td style="padding:10px 12px">Yes — trivially</td>
            </tr>
            <tr style="border-bottom:1px solid var(--border)">
                <td style="padding:10px 12px">Secure?</td>
                <td style="padding:10px 12px">No — not encryption</td>
                <td style="padding:10px 12px">No — not encryption</td>
            </tr>
            <tr style="border-bottom:1px solid var(--border)">
                <td style="padding:10px 12px">Main use</td>
                <td style="padding:10px 12px">Binary data in text contexts</td>
                <td style="padding:10px 12px">Special chars in URLs</td>
            </tr>
            <tr>
                <td style="padding:10px 12px">Where you'll see it</td>
                <td style="padding:10px 12px">JWT tokens, data URIs, MIME email, HTTP Basic Auth</td>
                <td style="padding:10px 12px">Query strings, form POST, OAuth params</td>
            </tr>
