>

<div class="workspace">
            <div class="input-group">
                <label>Your Text</label>
                <textarea id="inputText" placeholder="Enter text to analyze character frequency...&#10;&#10;Example:&#10;The quick brown fox jumps over the lazy dog" style="min-height:150px"></textarea>
            </div>

            <div style="display:flex;gap:10px;margin-bottom:15px;flex-wrap:wrap">
                <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
                    <input type="checkbox" id="caseSensitive">
                    <span style="font-size:0.9rem">Case sensitive</span>
                </label>
                <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
                    <input type="checkbox" id="lettersOnly" checked>
                    <span style="font-size:0.9rem">Letters only (A-Z)</span>
                </label>
                <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
                    <input type="checkbox" id="includeSpaces">
                    <span style="font-size:0.9rem">Include spaces</span>
                </label>
            </div>

            <div class="button-group">
                <button class="btn btn-primary" onclick="analyzeFrequency()">Analyze Frequency</button>
                <button class="btn btn-secondary" onclick="clearAll()">Clear</button>
                <button class="btn btn-success" onclick="exportData()">Export CSV</button>
            </div>

            <div id="results" style="display:none;margin-top:20px">
                <div class="summary-grid" id="summary"></div>
                
                <div style="background:var(--light);padding:20px;border-radius:12px;border:1px solid var(--border);margin-bottom:15px">
                    <h3 style="color:var(--primary);margin-bottom:15px">Character Distribution</h3>
                    <div class="char-grid" id="charGrid"></div>
                </div>

                <div style="background:var(--light);padding:20px;border-radius:12px;border:1px solid var(--border)">
                    <h3 style="color:var(--primary);margin-bottom:15px">Frequency Chart</h3>
                    <div id="chart"></div>
                </div>
            </div>
        </div>

        
        <!-- Share Bar -->

<style is:global>
.char-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(80px,1fr));gap:10px;margin-top:15px}
        .char-card{background:var(--input-bg);padding:12px;border-radius:8px;text-align:center;border:1px solid var(--border);transition:all 0.2s}
