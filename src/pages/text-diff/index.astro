<ToolLayout
  title="Text Diff Checker - Compare Two Texts Online | Webutilbox"
  description="Compare two texts and highlight the differences side by side. Supports line-by-line and word-by-word diff. Free online text difference checker tool."
  canonical={canonical}
  ogImage="https://webutilbox.com/assets/og/og-text-tools.svg"
  keywords="text diff, compare text online, text difference checker, diff tool, text comparison, code diff, document compare"
  h1="📝 Text Diff Checker"
  subtitle="Compare two texts and see differences highlighted. Perfect for code review, document comparison, and version control."
  lastUpdated=""
  shareText="Free%20online%20Text%20Diff%20Checker%20on%20Webutilbox.%20Privacy-focused%2C%20runs%20100%25%20in%20your%20browser."
