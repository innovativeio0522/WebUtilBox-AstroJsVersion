<div class="workspace">
            <!-- Preview -->
            <div style="margin-bottom: 20px;">
                <label style="font-size: 0.9rem; margin-bottom: 10px; display: block; font-weight: 600;">Preview</label>
                <div id="gridContainer" class="grid-preview">
                </div>
            </div>

            <!-- Controls -->
            <div class="grid-controls-grid">
                <!-- Columns -->
                <div>
                    <label style="font-size: 0.85rem; margin-bottom: 6px; display: block;">Columns</label>
                    <input type="range" id="columns" min="1" max="6" value="3" oninput="updateGrid()" style="width: 100%;">
                    <div style="text-align: center; font-size: 0.85rem; color: var(--gray); margin-top: 4px;"><span id="columnsValue">3</span></div>
                </div>

                <!-- Rows -->
                <div>
                    <label style="font-size: 0.85rem; margin-bottom: 6px; display: block;">Rows</label>
                    <input type="range" id="rows" min="1" max="6" value="2" oninput="updateGrid()" style="width: 100%;">
                    <div style="text-align: center; font-size: 0.85rem; color: var(--gray); margin-top: 4px;"><span id="rowsValue">2</span></div>
                </div>

                <!-- Column Gap -->
                <div>
                    <label style="font-size: 0.85rem; margin-bottom: 6px; display: block;">Column Gap (px)</label>
                    <input type="range" id="columnGap" min="0" max="50" value="10" oninput="updateGrid()" style="width: 100%;">
                    <div style="text-align: center; font-size: 0.85rem; color: var(--gray); margin-top: 4px;"><span id="columnGapValue">10</span>px</div>
                </div>

                <!-- Row Gap -->
                <div>
                    <label style="font-size: 0.85rem; margin-bottom: 6px; display: block;">Row Gap (px)</label>
                    <input type="range" id="rowGap" min="0" max="50" value="10" oninput="updateGrid()" style="width: 100%;">
                    <div style="text-align: center; font-size: 0.85rem; color: var(--gray); margin-top: 4px;"><span id="rowGapValue">10</span>px</div>
                </div>

                <!-- Justify Items -->
                <div>
                    <label style="font-size: 0.85rem; margin-bottom: 6px; display: block;">Justify Items</label>
                    <select id="justifyItems" onchange="updateGrid()" style="width: 100%; padding: 10px; font-size: 0.9rem;">
                        <option value="stretch">stretch</option>
                        <option value="start">start</option>
                        <option value="end">end</option>
                        <option value="center">center</option>
                    </select>
                </div>

                <!-- Align Items -->
                <div>
                    <label style="font-size: 0.85rem; margin-bottom: 6px; display: block;">Align Items</label>
                    <select id="alignItems" onchange="updateGrid()" style="width: 100%; padding: 10px; font-size: 0.9rem;">
                        <option value="stretch">stretch</option>
                        <option value="start">start</option>
                        <option value="end">end</option>
                        <option value="center">center</option>
                    </select>
                </div>
            </div>

            <!-- CSS Output -->
            <div>
                <label style="font-size: 0.9rem; margin-bottom: 8px; display: block; font-weight: 600;">CSS Code</label>
                <textarea id="cssOutput" readonly style="width: 100%; height: 150px; padding: 12px; font-family: 'Courier New', monospace; font-size: 0.9rem; background: var(--dark); border: 1px solid var(--border); border-radius: 8px; resize: vertical; margin-bottom: 10px;"></textarea>
                <button class="btn btn-success" onclick="copyCss()" style="width: 100%;">Copy CSS</button>
            </div>
        </div>

        
        <!-- Share Bar -->

