<div class="workspace">
            <div class="find-replace-grid">
                <!-- Left: Text Input -->
                <div>
                    <label style="font-size: 0.9rem; margin-bottom: 8px;">Input Text</label>
                    <textarea id="inputText" placeholder="Paste your text here..." style="min-height: 300px; font-size: 0.9rem;"></textarea>
                </div>
                
                <!-- Right: Options -->
                <div>
                    <div style="display: grid; gap: 10px;">
                        <div>
                            <label style="font-size: 0.85rem; margin-bottom: 6px;">Find:</label>
                            <input type="text" id="findText" placeholder="Text to find..." style="padding: 10px; font-size: 0.9rem;">
                        </div>
                        
                        <div>
                            <label style="font-size: 0.85rem; margin-bottom: 6px;">Replace with:</label>
                            <input type="text" id="replaceText" placeholder="Replacement text..." style="padding: 10px; font-size: 0.9rem;">
                        </div>
                        
                        <div style="background: var(--light); padding: 10px; border-radius: 8px; border: 1px solid var(--border);">
                            <label style="display: flex; align-items: center; gap: 8px; cursor: pointer; margin-bottom: 8px;">
                                <input type="checkbox" id="caseSensitive">
                                <span style="font-size: 0.85rem;">Case Sensitive</span>
                            </label>
                            <label style="display: flex; align-items: center; gap: 8px; cursor: pointer; margin-bottom: 8px;">
                                <input type="checkbox" id="wholeWord">
                                <span style="font-size: 0.85rem;">Match Whole Word</span>
                            </label>
                            <label style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
                                <input type="checkbox" id="useRegex">
                                <span style="font-size: 0.85rem;">Use Regex</span>
                            </label>
                        </div>
                        
                        <div class="button-group" style="display: grid; gap: 8px;">
                            <button class="btn btn-primary" onclick="findMatches()" style="width: 100%; padding: 10px;">Find</button>
                            <button class="btn btn-success" onclick="replaceAll()" style="width: 100%; padding: 10px;">Replace All</button>
                            <button class="btn btn-secondary" onclick="copyResult()" style="width: 100%; padding: 8px; font-size: 0.85rem;">Copy Result</button>
                            <button class="btn btn-secondary" onclick="clearAll()" style="width: 100%; padding: 8px; font-size: 0.85rem;">Clear</button>
                        </div>
                        
                        <div id="matchStats" style="background: var(--light); padding: 10px; border-radius: 8px; border: 1px solid var(--border); display: none;">
                            <div style="font-size: 0.85rem; color: var(--gray); margin-bottom: 5px;">Matches Found:</div>
                            <div style="font-size: 1.5rem; font-weight: bold; color: var(--primary);" id="matchCount">0</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="output-container show" id="outputContainer" style="margin-top: 15px; display: none;">
                <div class="output-label">Result</div>
                <div class="output-content" id="outputText" style="white-space: pre-wrap; font-size: 0.9rem;"></div>
