  subtitle="Advanced text search and replace with regex support, case sensitivity, and whole word matching."
  lastUpdated=""
  shareText="Free%20online%20Find%20and%20Replace%20on%20Webutilbox.%20Privacy-focused%2C%20runs%20100%25%20in%20your%20browser."
