                </div>
                <div class="input-group">
                    <label>Overtime Hours Per Week</label>
                    <input type="number" id="overtimeHours" value="0" min="0" max="80" step="0.5">
                </div>
                <div class="input-group">
                    <label>Overtime Rate Multiplier</label>
                    <input type="number" id="overtimeRate" value="1.5" min="1" max="3" step="0.1">
                    <small>1.5 = time and a half, 2.0 = double time</small>
                </div>
                <div class="input-group">
                    <label>Annual Bonus ($)</label>
                    <input type="number" id="bonus" value="0" min="0" step="100">
                </div>
                <div class="input-group">
                    <label>Tax Rate (%)</label>
                    <input type="number" id="taxRate" value="25" min="0" max="100" step="0.1">
                    <small>Estimated total tax (federal + state + local)</small>
                </div>
                <div class="input-group">
                    <label>Other Deductions ($/month)</label>
                    <input type="number" id="deductions" value="0" min="0" step="10">
