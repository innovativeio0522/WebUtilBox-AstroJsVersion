                    <label>Enter Your Salary</label>
                    <div style="display: flex; gap: 10px;">
                        <input type="number" id="salaryAmount" value="25" min="0" step="0.01" style="flex: 1;">
                        <select id="salaryPeriod" style="flex: 0 0 150px;">
