---
import BaseLayout from '../layouts/BaseLayout.astro';

const canonical = 'https://webutilbox.com/backlinks';
---

<BaseLayout
    title="Backlinks & Partners - Webutilbox"
    description="Explore our partner websites, directories, and developer resource listings. Learn how you can link to Webutilbox and exchange backlinks."
    canonical={canonical}
    keywords="backlinks, partner websites, web directories, developer resources, link exchange, webutilbox links"
>
    <header>
        <div class="header-content">
            <a href="/" class="logo">
                <span>🧰</span>
                <span>Webutilbox</span>
            </a>
        </div>
    </header>

    <div class="container" style="max-width: 900px; margin: 0 auto; padding: 40px 20px;">
        <h1 style="text-align: center; margin-bottom: 10px; background: linear-gradient(135deg, #fb923c 0%, #ea580c 50%, #dc2626 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Backlinks & Partners</h1>
        <p style="text-align: center; color: var(--gray); font-size: 1.1rem; margin-bottom: 50px;">
            A collection of curated web directories, developer resources, and trusted partner sites.
        </p>

        <!-- Section 1: Our Backlinks & Where We Are Featured -->
        <div class="section-card" style="background: rgba(24, 24, 27, 0.6); backdrop-filter: blur(12px); border: 1px solid var(--border); padding: 30px; border-radius: 16px; margin-bottom: 40px; box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);">
            <h2 style="margin-bottom: 20px; font-size: 1.6rem; color: var(--white); display: flex; align-items: center; gap: 10px;">
                <span>🔗</span> Directory Listings & Verification
            </h2>
            <p style="color: var(--gray); line-height: 1.8; margin-bottom: 25px;">
                Webutilbox is verified on and listed in these platforms:
            </p>
            
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 20px; align-items: center; justify-items: center;">
                <a href="https://www.producthunt.com" target="_blank" rel="noopener noreferrer" style="width: 100%; display: flex; flex-direction: column; padding: 20px; background: rgba(10, 10, 10, 0.5); border: 1px solid var(--border); border-radius: 12px; text-decoration: none; transition: all 0.3s ease; box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);">
                    <span style="font-size: 1.8rem; margin-bottom: 10px;">😺</span>
                    <strong style="color: var(--white); font-size: 1.1rem; margin-bottom: 5px;">Product Hunt</strong>
                    <span style="color: var(--gray); font-size: 0.85rem; line-height: 1.4;">Find and support Webutilbox during our Product Hunt launch.</span>
                </a>
                
                <div style="display: flex; justify-content: center; align-items: center; width: 100%;">
                    <a href="https://dang.ai" target="_blank" rel="dofollow noopener" style="display:inline-block;text-decoration:none; transition: transform 0.3s ease;"><img src="https://assets.dang.ai/badges/dang-verified-dark.png" alt="Verified on DANG!" width="260" height="94" style="display:block;width:260px;max-width:100%;height:auto;border:0;outline:none;text-decoration:none;" /></a>
                </div>

                <div style="display: flex; justify-content: center; align-items: center; width: 100%;">
                    <a href="https://twelve.tools" target="_blank" style="display:inline-block;text-decoration:none; transition: transform 0.3s ease;"><img src="https://twelve.tools/badge0-white.svg" alt="Featured on Twelve Tools" width="200" height="54" style="display:block;width:200px;max-width:100%;height:auto;border:0;outline:none;text-decoration:none;" /></a>
                </div>
            </div>
        </div>

        <!-- Section 2: How to Link to Us -->
        <div class="section-card" style="background: rgba(24, 24, 27, 0.6); backdrop-filter: blur(12px); border: 1px solid var(--border); padding: 30px; border-radius: 16px; margin-bottom: 40px; box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);">
            <h2 style="margin-bottom: 20px; font-size: 1.6rem; color: var(--white); display: flex; align-items: center; gap: 10px;">
                <span>🛠️</span> How to Link to Us
            </h2>
            <p style="color: var(--gray); line-height: 1.8; margin-bottom: 20px;">
                If you find Webutilbox useful and want to link to us from your resource page, blog post, or website, feel free to use one of the standard link formats below.
            </p>

            <!-- Code snippet 1 -->
            <div style="margin-bottom: 25px;">
                <h3 style="color: var(--white); font-size: 1.1rem; margin-bottom: 10px;">1. Standard Text Link</h3>
                <p style="color: var(--gray); font-size: 0.9rem; margin-bottom: 10px;">Preview: <a href="https://webutilbox.com" target="_blank" style="color: var(--primary); text-decoration: underline;">Webutilbox - Free Client-Side Developer Tools</a></p>
                <div style="position: relative; background: #0c0c0e; border: 1px solid var(--border); border-radius: 8px; padding: 15px; font-family: monospace; font-size: 0.9rem; overflow-x: auto;">
                    <code id="textLinkHtml" style="color: #cbd5e1;">&lt;a href="https://webutilbox.com" title="Webutilbox - Free Client-Side Developer Tools"&gt;Webutilbox - Free Client-Side Developer Tools&lt;/a&gt;</code>
                    <button onclick="copyToClipboard('textLinkHtml')" style="position: absolute; right: 10px; top: 10px; padding: 6px 12px; background: var(--primary); color: white; border: none; border-radius: 6px; font-size: 0.8rem; cursor: pointer; font-family: sans-serif; font-weight: 600; transition: background 0.2s; border: 1px solid rgba(255,255,255,0.1);">Copy Code</button>
                </div>
            </div>

            <!-- Code snippet 2 -->
            <div>
                <h3 style="color: var(--white); font-size: 1.1rem; margin-bottom: 10px;">2. Detailed Description Link</h3>
                <p style="color: var(--gray); font-size: 0.9rem; margin-bottom: 10px;">Preview: <strong><a href="https://webutilbox.com" target="_blank" style="color: var(--primary); text-decoration: underline;">Webutilbox</a></strong> - 94+ free, privacy-focused, offline-first web utility tools for developers and designers.</p>
                <div style="position: relative; background: #0c0c0e; border: 1px solid var(--border); border-radius: 8px; padding: 15px; font-family: monospace; font-size: 0.9rem; overflow-x: auto;">
                    <code id="descLinkHtml" style="color: #cbd5e1;">&lt;p&gt;&lt;strong&gt;&lt;a href="https://webutilbox.com"&gt;Webutilbox&lt;/a&gt;&lt;/strong&gt; - 94+ free, privacy-focused, offline-first web utility tools for developers and designers.&lt;/p&gt;</code>
                    <button onclick="copyToClipboard('descLinkHtml')" style="position: absolute; right: 10px; top: 10px; padding: 6px 12px; background: var(--primary); color: white; border: none; border-radius: 6px; font-size: 0.8rem; cursor: pointer; font-family: sans-serif; font-weight: 600; transition: background 0.2s; border: 1px solid rgba(255,255,255,0.1);">Copy Code</button>
                </div>
            </div>
        </div>

        <!-- Section 3: Link Exchange / Partner Request -->
        <div class="section-card" style="background: rgba(24, 24, 27, 0.6); backdrop-filter: blur(12px); border: 1px solid var(--border); padding: 30px; border-radius: 16px; box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);">
            <h2 style="margin-bottom: 20px; font-size: 1.6rem; color: var(--white); display: flex; align-items: center; gap: 10px;">
                <span>🤝</span> Request a Link Exchange
            </h2>
            <p style="color: var(--gray); line-height: 1.8; margin-bottom: 20px;">
                Are you a creator of a developer tool, software project, design resource, or web directory? We would love to partner with you! 
                If you place a link back to Webutilbox on your website, contact us with details about your site, and we will review it for inclusion in our partner list.
            </p>
            <div style="display: flex; justify-content: center; margin-top: 25px;">
                <a href="/contact" style="display: inline-block; padding: 14px 28px; background: linear-gradient(135deg, #f97316 0%, #ea580c 100%); color: var(--white); font-weight: 600; text-decoration: none; border-radius: 8px; box-shadow: 0 4px 14px rgba(249, 115, 22, 0.4); transition: transform 0.2s, box-shadow 0.2s; border: 1px solid rgba(255,255,255,0.1);" onmouseover="this.style.transform='translateY(-2px)';" onmouseout="this.style.transform='translateY(0)';" >
                    Get in Touch for Partnership
                </a>
            </div>
        </div>
    </div>

    <!-- Client-side script for copying text -->
    <script is:inline>
        function copyToClipboard(elementId) {
            const codeText = document.getElementById(elementId).textContent;
            navigator.clipboard.writeText(codeText).then(() => {
                if (typeof showToast === 'function') {
                    showToast('Code snippet copied!');
                } else {
                    alert('Copied to clipboard!');
                }
            }).catch(err => {
                console.error('Failed to copy: ', err);
            });
        }
    </script>
</BaseLayout>

<style>
    /* Hover effects for directory cards */
    a[target="_blank"] {
        transition: all 0.3s ease;
    }
    a[target="_blank"]:hover {
        border-color: var(--primary) !important;
        transform: translateY(-3px);
        box-shadow: 0 8px 16px rgba(249, 115, 22, 0.15) !important;
    }
</style>
