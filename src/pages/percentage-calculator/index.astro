---
import ToolLayout from '../../layouts/ToolLayout.astro';

const canonical = 'https://webutilbox.com/percentage-calculator/';
const jsonLd = {"@context":"https://schema.org","@graph":[{"@type":"WebApplication","name":"Percentage Calculator — % of a Number, Change & Ratio | Webutilbox","url":"https://webutilbox.com/percentage-calculator/","description":"Free percentage calculator with 3 modes: find X% of a number, calculate what percent X is of Y, and work out percentage increase or decrease. Results update instantly as you type.","applicationCategory":"UtilitiesApplication","operatingSystem":"Web Browser","browserRequirements":"Requires JavaScript","featureList":["Calculate X% of a number","Find what percent X is of Y","Calculate percentage increase or decrease","Real-time results — no button click needed","Works with decimal values","100% client-side"],"offers":{"@type":"Offer","price":"0","priceCurrency":"USD"},"creator":{"@type":"Organization","name":"Webutilbox","url":"https://webutilbox.com"}},{"@type":"HowTo","name":"How to Use the Percentage Calculator","step":[{"@type":"HowToStep","position":1,"name":"Choose your calculation type","text":"Pick the calculator that matches your question: 'What is X% of Y?' for discounts and tips, 'X is what % of Y?' for ratios and scores, or '% Increase/Decrease' for tracking change between two values."},{"@type":"HowToStep","position":2,"name":"Enter your numbers","text":"Type your values into the input fields. The result appears instantly — no button click required."},{"@type":"HowToStep","position":3,"name":"Read the result","text":"The answer displays immediately below the inputs. For percentage change, the calculator automatically labels the result as 'increase' or 'decrease'."}]},{"@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How do I calculate what percentage one number is of another?","acceptedAnswer":{"@type":"Answer","text":"Divide the part by the whole and multiply by 100. For example, 30 is what percent of 120? (30 / 120) x 100 = 25%. The calculator handles this automatically — enter the two numbers in the 'X is what % of Y?' section."}},{"@type":"Question","name":"How do I calculate a percentage increase or decrease?","acceptedAnswer":{"@type":"Answer","text":"Percentage change = ((new value - old value) / old value) x 100. A positive result is an increase; negative is a decrease. For example, price went from $80 to $100: ((100 - 80) / 80) x 100 = 25% increase."}},{"@type":"Question","name":"How do I find the original value before a percentage was applied?","acceptedAnswer":{"@type":"Answer","text":"Original = final value / (1 + percentage/100) for increases, or final value / (1 - percentage/100) for decreases. If a price is $90 after a 10% discount: 90 / (1 - 0.10) = 90 / 0.90 = $100 original price."}},{"@type":"Question","name":"What is the difference between percentage points and percent?","acceptedAnswer":{"@type":"Answer","text":"Percentage points measure the arithmetic difference between two percentages. If interest rates go from 2% to 5%, that is a 3 percentage point increase, but a 150% relative increase. These are very different things — be careful which one is being reported."}},{"@type":"Question","name":"How do I calculate compound percentage growth?","acceptedAnswer":{"@type":"Answer","text":"For compound growth over multiple periods, use: final = initial x (1 + rate)^periods. For example, 5% annual growth over 3 years: 1000 x (1.05)^3 = $1,157.63. Use the Compound Interest Calculator for more detailed compound growth calculations."}}]},{"@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://webutilbox.com/"},{"@type":"ListItem","position":2,"name":"All Tools","item":"https://webutilbox.com/tools/"},{"@type":"ListItem","position":3,"name":"Percentage Calculator","item":"https://webutilbox.com/percentage-calculator/"}]}]};
---

<ToolLayout
  title="Percentage Calculator — % of Number, Change &amp; Ratio | Webutilbox"
  description="Free percentage calculator with 3 modes: find X% of a number, calculate what percent X is of Y, and work out percentage increase or decrease. Results update as you type."
  canonical={canonical}
  ogImage="https://webutilbox.com/assets/og/og-calculators.svg"
  keywords="percentage calculator, percent calculator, percentage increase calculator, percentage decrease calculator, percentage change calculator, what is x percent of y, percent of a number calculator"
  h1="% Percentage Calculator — 3 Calculators in One"
  subtitle="Enter any two numbers to instantly calculate a percentage — no formulas, no button clicks. Find X% of a number, calculate a ratio, or work out percentage change. This free percent calculator provides instant results as you type."
  lastUpdated="2026-06-05"
  shareText="Free%20percentage%20calculator%20%E2%80%94%203%20calculators%20in%20one%3A%20%25%20of%20a%20number%2C%20ratio%2C%20and%20increase%2Fdecrease.%20Results%20update%20as%20you%20type."
  shareUrl={canonical}
  embedUrl={canonical}
  embedTitle="Percentage Calculator — % of Number, Change &amp; Ratio -- Webutilbox"
  embedHeight={600}
  toolCss={true}
  jsonLd={jsonLd}
>

<div class="workspace">
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 15px;">
                <!-- Calculator 1 -->
                <div style="background: var(--light); padding: 15px; border-radius: 10px; border: 1px solid var(--border);">
                    <h3 style="font-size: 0.95rem; margin-bottom: 4px; color: var(--primary);">What is X% of Y?</h3>
                    <p style="font-size:0.75rem;color:var(--gray);margin-bottom:10px">e.g. What is 15% of $84? → <strong style="color:var(--white)">$12.60</strong></p>
                    <div style="display: grid; grid-template-columns: auto 1fr auto 1fr; gap: 8px; align-items: center; margin-bottom: 10px; font-size: 0.85rem;">
                        <span>What is</span>
                        <input type="number" id="percent1" value="10" oninput="calc1()" style="padding: 8px; font-size: 0.9rem;">
                        <span>% of</span>
                        <input type="number" id="value1" value="100" oninput="calc1()" style="padding: 8px; font-size: 0.9rem;">
                    </div>
                    <div style="background: var(--input-bg); padding: 10px; border-radius: 6px; text-align: center; font-size: 1.1rem; color: var(--primary); font-weight: 600;" id="result1">10</div>
                </div>

                <!-- Calculator 2 -->
                <div style="background: var(--light); padding: 15px; border-radius: 10px; border: 1px solid var(--border);">
                    <h3 style="font-size: 0.95rem; margin-bottom: 4px; color: var(--primary);">X is what % of Y?</h3>
                    <p style="font-size:0.75rem;color:var(--gray);margin-bottom:10px">e.g. 43 out of 50 marks → <strong style="color:var(--white)">86%</strong></p>
                    <div style="display: grid; grid-template-columns: 1fr auto 1fr; gap: 8px; align-items: center; margin-bottom: 10px; font-size: 0.85rem;">
                        <input type="number" id="value2a" value="25" oninput="calc2()" style="padding: 8px; font-size: 0.9rem;">
                        <span>is what % of</span>
                        <input type="number" id="value2b" value="100" oninput="calc2()" style="padding: 8px; font-size: 0.9rem;">
                    </div>
                    <div style="background: var(--input-bg); padding: 10px; border-radius: 6px; text-align: center; font-size: 1.1rem; color: var(--primary); font-weight: 600;" id="result2">25%</div>
                </div>

                <!-- Calculator 3 -->
                <div style="background: var(--light); padding: 15px; border-radius: 10px; border: 1px solid var(--border);">
                    <h3 style="font-size: 0.95rem; margin-bottom: 4px; color: var(--primary);">% Increase / Decrease</h3>
                    <p style="font-size:0.75rem;color:var(--gray);margin-bottom:10px">e.g. Price from $80 → $100 → <strong style="color:var(--white)">25% increase</strong></p>
                    <div style="display: grid; grid-template-columns: auto 1fr auto 1fr; gap: 8px; align-items: center; margin-bottom: 10px; font-size: 0.85rem;">
                        <span>From</span>
                        <input type="number" id="value3a" value="100" oninput="calc3()" style="padding: 8px; font-size: 0.9rem;">
                        <span>To</span>
                        <input type="number" id="value3b" value="120" oninput="calc3()" style="padding: 8px; font-size: 0.9rem;">
                    </div>
                    <div style="background: var(--input-bg); padding: 10px; border-radius: 6px; text-align: center; font-size: 1.1rem; color: var(--primary); font-weight: 600;" id="result3">20% increase</div>
                </div>
            </div>
        </div><!-- end workspace -->

        <!-- Share Bar -->




<script src="/js/percentage-calculator.js" defer></script>

<div class="info-section" slot="info">

</div>

</ToolLayout>