                    </div>
                </div>

                <!-- Download Options -->
                <div style="background: var(--light); border-radius: 8px; padding: 15px; margin-bottom: 15px; border: 1px solid var(--border);">
                    <div style="font-size: 0.85rem; color: var(--gray); margin-bottom: 10px;">Download Individual Sizes</div>
