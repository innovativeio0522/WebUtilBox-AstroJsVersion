            </div>

            <div class="encryption-grid">
                <!-- Left: Plain Text -->
                <div>
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
                        <label style="font-size: 0.9rem; margin: 0;">Plain Text</label>
                        <button class="btn btn-primary" onclick="encryptText()" style="padding: 6px 16px; font-size: 0.85rem;">?? Encrypt</button>
                    </div>
                    <textarea id="plainText" placeholder="Enter text to encrypt..." style="min-height: 250px; font-size: 0.9rem;"></textarea>
