<div class="workspace">
            <!-- Password Input -->
            <div style="margin-bottom: 15px;">
                <label style="font-size: 0.9rem; margin-bottom: 8px;">Encryption Password</label>
                <div style="position: relative;">
                    <input type="password" id="passwordInput" placeholder="Enter a strong password..." style="padding: 12px; font-size: 1rem; padding-right: 50px;">
                    <button onclick="togglePassword()" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); background: none; border: none; cursor: pointer; font-size: 1.3rem; color: var(--gray);" id="toggleBtn">???</button>
                </div>
