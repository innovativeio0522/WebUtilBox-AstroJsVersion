---

<BaseLayout
    title="All Tools | Webutilbox"
    description="Browse our complete collection of free online utilities, organized by category."
    canonical={canonical}
    keywords="all tools, webutilbox tools, free online tools, developer tools, web tools"
>
    <header>
        <div class="header-content">
            <a href="/" class="logo">
                <span>💼</span>
                <span>Webutilbox</span>
            </a>
            <a href="/" class="all-tools-btn">Home</a>
        </div>
    </header>

    <div class="container" style="max-width: 1400px;">
        <div class="hero" style="text-align: center; margin-bottom: 40px;">
            <h1 style="color: var(--primary);">All Tools</h1>
            <p style="color: var(--gray); font-size: 1.1rem; max-width: 600px; margin: 10px auto 30px;">
                Browse our complete collection of free online utilities, organized by category.
            </p>
            <input 
                type="text" 
                id="tool-search" 
                placeholder="Search tools by name or description... 🔍"
                style="width: 100%; max-width: 500px; padding: 12px 20px; font-size: 1rem; border-radius: 8px; border: 2px solid var(--border); background: var(--card-bg); color: var(--white);"
            />
        </div>

        {toolCategories.map(category => (
            <div class="category-section" data-category={category.name.toLowerCase()} style="margin-bottom: 60px;">
                <div style="background: rgba(255,255,255,0.02); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.06); border-radius: var(--radius); padding: 24px; margin-bottom: 20px;">
                    <h2 class="category-title" style="display: flex; align-items: center; gap: 10px; font-size: 1.5rem; color: var(--primary); margin: 0 0 8px;">
                        <span>{category.icon}</span>
                        <span>{category.name}</span>
                    </h2>
                    <p style="color: var(--gray); font-size: 0.95rem; margin: 0;">
                        {category.description}
                    </p>
                </div>
                <div class="tools-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 12px;">
                    {category.tools.map(tool => (
                        <a 
                            href={tool.href} 
                            class="tool-card" 
                            data-tool-name={tool.name.toLowerCase()} 
                            data-tool-desc={tool.desc.toLowerCase()}
                            style="display: flex; flex-direction: column; align-items: center; text-align: center; padding: 16px 12px; background: rgba(255,255,255,0.02); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.06); border-radius: var(--radius); text-decoration: none; color: var(--white); transition: all 0.2s; box-shadow: var(--shadow);"
                        >
                            <div class="tool-icon-box" style="width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; font-size: 1.25rem; margin-bottom: 10px; color: var(--primary); font-weight: bold;">
                                {tool.icon}
                            </div>
                            <h3 class="tool-title" style="font-size: 0.875rem; margin-bottom: 4px; font-weight: 600;">{tool.name}</h3>
                            <p class="tool-desc" style="font-size: 0.65rem; color: var(--gray); line-height: 1.3; margin: 0;">{tool.desc}</p>
                        </a>
                    ))}
                </div>
            </div>
        ))}

        <ShareBar shareText={shareText} shareUrl={shareUrl} />
    </div>

    <link slot="head" rel="stylesheet" href="/assets/css/home.css" />
    <script slot="head" is:inline>
        document.addEventListener('DOMContentLoaded', () => {
            const searchInput = document.getElementById('tool-search');
            if (!searchInput) {
                console.error('Search input not found');
                return;
            }
            
            searchInput.addEventListener('input', (e) => {
                const searchTerm = e.target.value.toLowerCase();
                const sections = document.querySelectorAll('.category-section');
                
                sections.forEach(section => {
                    const tools = section.querySelectorAll('.tool-card');
                    let visibleCount = 0;
                    
                    tools.forEach(card => {
                        const name = card.getAttribute('data-tool-name');
                        const desc = card.getAttribute('data-tool-desc');
                        
                        if (searchTerm === '' || (name && name.includes(searchTerm)) || (desc && desc.includes(searchTerm))) {
                            card.style.display = 'flex';
                            visibleCount++;
                        } else {
                            card.style.display = 'none';
                        }
                    });
                    
                    section.style.display = searchTerm === '' || visibleCount > 0 ? 'block' : 'none';
                });
            });
        });
    </script>
</BaseLayout>
