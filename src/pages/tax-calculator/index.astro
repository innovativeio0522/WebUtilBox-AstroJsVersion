  description="Calculate income tax based on your salary and tax brackets. Supports multiple filing statuses. Estimate your tax liability with our free tax calculator."
  canonical={canonical}
  ogImage="https://webutilbox.com/assets/og/og-calculators.svg"
  keywords="tax calculator, income tax calculator, salary tax calculator, take home pay calculator, federal tax calculator, state tax calculator"
  h1="🧾 Global Tax Calculator"
  subtitle="Calculate income tax and take-home pay for 10 countries worldwide"
  lastUpdated=""
  shareText="Free%20online%20Tax%20Calculator%20on%20Webutilbox.%20Privacy-focused%2C%20runs%20100%25%20in%20your%20browser."
  shareUrl={canonical}
  embedUrl={canonical}
  embedTitle="Tax Calculator - Income Tax -- Webutilbox"
  embedHeight={600}
  toolCss={true}
  jsonLd={jsonLd}
>

<div class="tool-content">
            <div class="input-section">
                <div class="input-group">
                    <label>Country</label>
                    <select id="country" onchange="updateTaxInfo()">
                        <option value="US">🇺🇸 United States</option>
                        <option value="UK">🇬🇧 United Kingdom</option>
                        <option value="CA">🇨🇦 Canada</option>
                        <option value="AU">🇦🇺 Australia</option>
                        <option value="IN">🇮🇳 India</option>
                        <option value="DE">🇩🇪 Germany</option>
