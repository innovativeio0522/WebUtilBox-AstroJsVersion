<input type="text" id="bgHex" value="#ffffff" style="width:100%;margin-top:10px;padding:10px;background:var(--input-bg);border:1px solid var(--border);border-radius:8px;color:var(--white)" oninput="updateFromHex('bg')">
</div>
</div>
<div class="preview-box" id="preview" style="background:#ffffff;color:#000000">
